# Sylva Platform Core — 环境变量配置
# 复制为 .env 后按需填入你的 API Key
# 本地使用 Ollama 时，所有 Key 都可以不填

# ═══════════════════════════════════════════════════════════════
#  服务器配置（必填）
# ═══════════════════════════════════════════════════════════════
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# ═══════════════════════════════════════════════════════════════
#  Ollama 本地模型（可选，默认自动检测 localhost:11434）
# ═══════════════════════════════════════════════════════════════
OLLAMA_URL=http://localhost:11434

# ═══════════════════════════════════════════════════════════════
#  远程 Provider API Key（按需填写，不填则该 Provider 不可用）
# ═══════════════════════════════════════════════════════════════
CLAUDE_API_KEY=                     # sk-ant-... (Anthropic)
OPENAI_API_KEY=                     # sk-... (OpenAI)
KIMI_API_KEY=                       # sk-kimi-... (Moonshot)
KIMI_CODE_API_KEY=                  # sk-kimi-... (Moonshot Coding)
GEMINI_API_KEY=                     # AIzaSy-... (Google)
DEEPSEEK_API_KEY=                   # sk-... (DeepSeek)
OPENROUTER_API_KEY=                 # sk-or-... (OpenRouter)
HERMES_API_KEY=                     # Hermes MCP 密钥

# ═══════════════════════════════════════════════════════════════
#  日志级别
# ═══════════════════════════════════════════════════════════════
LOG_LEVEL=info
